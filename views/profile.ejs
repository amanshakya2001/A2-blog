<%- include("particles/header") %>
<%- include("particles/navbar") %>
<link rel="stylesheet" href="/css/profile.css">

<section id="profile" class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card mb-4">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="avatar avatar-xl">
                            <%= user.fullname.charAt(0).toUpperCase() %>
                        </div>
                        <div>
                            <h1 class="m-0"><%= user.fullname %></h1>
                            <small class="text-muted">Joined <%= user.createdAt %></small>
                        </div>
                        <div class="ms-auto d-none d-sm-block">
                            <a href="/write" class="btn btn-primary">Write</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-10">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h2 class="m-0">My Blogs</h2>
                    <span class="text-muted text-sm"><%= blogs.length %> posts</span>
                </div>
                <div class="row g-3">
                    <% blogs.forEach(blog => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100">
                                <img src="<%= blog.coverImage %>" class="card-img-top" alt="<%= blog.title %> cover image" width="100%" height="200">
                                <div class="card-body">
                                    <h5 class="card-title text-truncate"><%= blog.title %></h5>
                                    <p class="card-text custom-truncate-3"><%= blog.content %></p>
                                </div>
                                <div class="card-footer border-0 bg-transparent">
                                    <p class="mb-0"><small class="mb-0 text-muted"><%= blog.updatedAt %></small></p>
                                    <p class="mb-3"><small class="mb-0 text-muted mb-3"><%= blog.author.fullname %></small></p>
                                    <a href="/blog/<%= blog._id %>" class="btn btn-primary d-table w-100">Read More</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                    <% if (blogs.length === 0) { %>
                        <p class="text-muted">You haven't written any blogs yet.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    
</section>

<%- include("particles/footer") %>