<%- include('./particles/header.ejs'); %>
<link rel="stylesheet" href="/css/login.css" />
<div class="container">
  <div class="card">
    <div class="header">
      <div class="logo">
        <p class="logo-text m-0">A<sup>2</sup></p>
      </div>
      <h1 class="title text-center text-white">Welcome back</h1>
      <p class="subtitle text-center text-white">Sign in to continue</p>
    </div>

    <form id="login-form" class="form">
      <div id="inlineAlert" class="alert alert-danger" style="display: none;"></div>
      <div class="row m-0">
        <label class="label" for="email">Email</label>
        <input class="input" type="email" id="email" name="email" placeholder="you@example.com" required />
      </div>

      <div class="row">
        <label class="label" for="password">Password</label>
        <div class="input-group">
          <input class="input has-toggle" type="password" id="password" name="password" placeholder="••••••••" required />
        </div>
      </div>

      <button class="button" type="button" id="loginBtn">Sign in</button>

      <p class="footer-note">
        Don't have an account?
        <a class="link" href="/register">Register</a>
      </p>
    </form>
  </div>
</div>
<script defer src="/scripts/login.js"></script>
<%- include('./particles/footer.ejs'); %>


